# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env

# SQLite databases (локальный likray.db не комитим — он создаётся при запуске)
*.db
*.sqlite3

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
pytest-cache-files-*/

# Logs / runtime
*.log
.claude/
.runtime/

# Бэкапы из start.ps1
*.bak

# Handover-архив (исторический artefact, не нужен в репо)
Likray_handover.zip

# ── Flutter ──────────────────────────────────────────────────────────────
# .dart_tool — кэш pub get (большой, быстро восстанавливается через `flutter pub get`)
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages

# build/ — общая папка билд-артефактов Flutter, НО build/web нам нужно
# опубликовать на Render Static Site, поэтому делаем точечное исключение.
frontend/build/*
!frontend/build/web/
